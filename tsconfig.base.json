{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "shared-dtos": ["libs/shared-dtos/src/index.ts"],
      "@design-system/shared-ui": ["libs/shared-ui/src/index.ts"],
      "@design-system/shared-ui/*": ["libs/shared-ui/src/*"],
      "@design-system/*": ["libs/shared-ui/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
